# Sauron-1 auto-boot capture config.
#
# The installer copies this to the SD card's BOOT partition as
# 'startracker.conf'. That partition is FAT and mounts on any laptop, so in the
# field (no screen) you can change capture settings by popping the SD into a
# laptop, editing this file, and rebooting the Pi.
#
# Each line is a shell variable assignment. Reboot the Pi to apply.

# How long to run on each power-on, in seconds.
# 999999 = keep capturing until you cut power or the disk fills.
DURATION=999999

# fixed  = hold one exposure/gain the whole time (use after you know the setting)
# bracket = sweep the BRACKET list (use to FIND the setting / map the model)
# Default is bracket: the exposure steps below are derived from the optical
# foundation photon model for f/1.4 (see "Exposure bracket from the photon
# model" in FIELD_NOTES.md). 10 ms is the on-orbit flight point; the rest map
# limiting magnitude up to the ~1 s ground trailing limit.
MODE=bracket

# --- fixed mode (used only when MODE=fixed, after you pick a winner) ---
EXPOSURE_US=100000        # shutter speed in microseconds (100000 = 0.1 s)
GAIN=2.0                  # analogue gain

# --- bracket mode: "exposure_us:gain" pairs, swept repeatedly ---
# Exposure sweep at fixed gain=2 (clean limiting-mag vs exposure curve):
BRACKET="5000:2,10000:2,20000:2,50000:2,100000:2,200000:2,500000:2,1000000:2"
# Alt: GAIN sweep at fixed 100 ms (find the Pi's noise/headroom sweet spot) --
#   BRACKET="100000:1,100000:2,100000:4,100000:8,100000:16"
FRAMES_PER_SETTING=5

# Save a JPEG quicklook this often (seconds); 0 disables previews.
PREVIEW_EVERY=5

# Stop capturing once free disk falls below this (GB).
MIN_FREE_GB=1.0

# Free text written into every session.json -- RECORD YOUR FOCUS STATE here,
# since you can't see a live preview in the field.
FOCUS_NOTE="defocused ~2px"
NOTE="joshua tree auto-boot"
